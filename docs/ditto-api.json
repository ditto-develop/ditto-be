  "info": {
    "title": "Ditto API",
    "description": "Start Game -> Solve Quiz -> Match Results -> Save Email -> Share (MVP)",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:4000"
    },
    {
      "url": "https://www.ditto.pics"
    }
  ],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateQuizDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "퀴즈 ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "question": {
            "type": "string",
            "description": "퀴즈 질문",
            "example": "사과 vs 바나나"
          },
          "quizSetId": {
            "type": "string",
            "description": "퀴즈 세트 ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "order": {
            "type": "number",
            "description": "퀴즈 순서",
            "example": 1
          }
        },
        "required": [
          "id",
          "question",
          "quizSetId"
        ]
      },
      "QuizDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "퀴즈 ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "question": {
            "type": "string",
            "description": "퀴즈 질문",
            "example": "사과 vs 바나나"
          },
          "quizSetId": {
            "type": "string",
            "description": "퀴즈 세트 ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "order": {
            "type": "number",
            "description": "퀴즈 순서",
            "nullable": true,
            "example": 1
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "생성일",
            "example": "2025-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "수정일",
            "example": "2025-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "question",
          "quizSetId",
          "createdAt",
          "updatedAt"
        ]
      },
      "QuizSetDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "퀴즈 세트 ID",
            "example": "cuid"
          },
          "week": {
            "type": "number",
            "description": "주차",
            "example": 1
          },
          "category": {
            "type": "string",
            "description": "카테고리",
            "example": "일상"
          },
          "title": {
            "type": "string",
            "description": "퀴즈 세트 제목",
            "example": "1주차 일상 퀴즈"
          },
          "description": {
            "type": "string",
            "description": "퀴즈 세트 설명",
            "example": "일상생활에 관한 퀴즈 세트입니다."
          },
          "startDate": {
            "format": "date-time",
            "type": "string",
            "description": "시작일",
            "example": "2025-12-01T00:00:00Z"
          },
          "endDate": {
            "format": "date-time",
            "type": "string",
            "description": "종료일",
            "example": "2025-12-08T00:00:00Z"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "생성일",
            "example": "2025-11-29T12:00:00Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "수정일",
            "example": "2025-11-29T12:00:00Z"
          },
          "isActive": {
            "type": "boolean",
            "description": "활성화 여부",
            "example": true
          }
        },
        "required": [
          "id",
          "week",
          "category",
          "title",
          "startDate",
          "endDate",
          "createdAt",
          "updatedAt",
          "isActive"
        ]
      },
      "CreateQuizSetDto": {
        "type": "object",
        "properties": {
          "week": {
            "type": "number",
            "description": "주차",
            "example": 1
          },
          "category": {
            "type": "string",
            "description": "카테고리",
            "example": "일상"
          },
          "title": {
            "type": "string",
            "description": "퀴즈 세트 제목",
            "example": "1주차 일상 퀴즈"
          },
          "description": {
            "type": "string",
            "description": "퀴즈 세트 설명",
            "example": "일상생활에 관한 퀴즈 세트입니다."
          },
          "startDate": {
            "type": "string",
            "description": "시작일",
            "example": "2025-12-01T00:00:00Z"
          }
        },
        "required": [
          "week",
          "category",
          "title",
          "startDate"
        ]
      },
      "UpdateQuizSetDto": {
        "type": "object",
        "properties": {
          "week": {
            "type": "number",
            "description": "주차",
            "example": 1
          },
          "category": {
            "type": "string",
            "description": "카테고리",
            "example": "일상"
          },
          "title": {
            "type": "string",
            "description": "퀴즈 세트 제목",
            "example": "1주차 일상 퀴즈"
          },
          "description": {
            "type": "string",
            "description": "퀴즈 세트 설명",
            "example": "일상생활에 관한 퀴즈 세트입니다."
          },
          "startDate": {
            "type": "string",
            "description": "시작일",
            "example": "2025-12-01T00:00:00Z"
          },
          "isActive": {
            "type": "boolean",
            "description": "활성화 여부",
            "example": true
          }
        }
      }
    }
  }
}