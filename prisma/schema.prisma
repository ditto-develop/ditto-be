generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String              @id @default(cuid())
  name                  String
  nickname              String
  phoneNumber           String              @unique
  email                 String?             @unique
  username              String?             @unique
  passwordHash          String?
  gender                String
  age                   Int
  birthDate             DateTime?
  joinedAt              DateTime            @default(now())
  leftAt                DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  roleId                Int
  chatMessages          ChatMessage[]
  chatParticipants      ChatParticipant[]
  sentMatchRequests     MatchRequest[]      @relation("MatchRequestFrom")
  receivedMatchRequests MatchRequest[]      @relation("MatchRequestTo")
  introNote             UserIntroNote?
  profile               UserProfile?
  quizProgresses        UserQuizProgress[]
  givenRatings          UserRating[]        @relation("RatingFrom")
  receivedRatings       UserRating[]        @relation("RatingTo")
  socialAccounts        UserSocialAccount[]
  role                  Role                @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("roles")
}

model UserSocialAccount {
  id             Int    @id @default(autoincrement())
  userId         String
  provider       String
  providerUserId String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("user_social_accounts")
}

model QuizSet {
  id             String             @id @default(cuid())
  week           Int
  category       String
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  matchingType   MatchingType       @default(ONE_TO_ONE)
  month          Int                @default(12)
  year           Int                @default(2025)
  matchRequests  MatchRequest[]
  quizzes        Quiz[]
  quizProgresses UserQuizProgress[]

  @@unique([year, month, week, category])
  @@map("quiz_sets")
}

model Quiz {
  id        String       @id @default(cuid())
  question  String
  order     Int
  quizSetId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  choices   Choice[]
  answers   QuizAnswer[]
  quizSet   QuizSet      @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model Choice {
  id      String       @id @default(cuid())
  text    String
  quizId  String
  order   Int
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@map("choices")
}

model QuizAnswer {
  id         String   @id @default(cuid())
  userId     String
  quizId     String
  choiceId   String
  answeredAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  choice     Choice   @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model UserQuizProgress {
  id          String             @id @default(cuid())
  userId      String
  year        Int                @default(2025)
  month       Int                @default(12)
  week        Int
  quizSetId   String
  status      QuizProgressStatus @default(NOT_STARTED)
  selectedAt  DateTime           @default(now())
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  quizSet     QuizSet            @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month, week])
  @@map("user_quiz_progresses")
}

model UserIntroNote {
  id        String   @id @default(cuid())
  userId    String   @unique
  answers   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_intro_notes")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  introduction    String?  @db.VarChar(300)
  preferredMinAge Int?
  preferredMaxAge Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  location        String?  @db.VarChar(100)
  profileImageUrl String?  @db.VarChar(500)
  occupation      String?  @db.VarChar(100)
  interests       String[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model MatchRequest {
  id               String             @id @default(cuid())
  quizSetId        String
  fromUserId       String
  toUserId         String
  status           MatchRequestStatus @default(PENDING)
  score            Float              @default(0)
  scoreBreakdown   Json?
  algorithmVersion String             @default("v1")
  requestedAt      DateTime           @default(now())
  respondedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  chatRoom         ChatRoom?
  fromUser         User               @relation("MatchRequestFrom", fields: [fromUserId], references: [id])
  quizSet          QuizSet            @relation(fields: [quizSetId], references: [id])
  toUser           User               @relation("MatchRequestTo", fields: [toUserId], references: [id])
  ratings          UserRating[]

  @@unique([quizSetId, fromUserId, toUserId])
  @@index([fromUserId, status])
  @@index([toUserId, status])
  @@map("match_requests")
}

model ChatRoom {
  id             String            @id @default(cuid())
  matchRequestId String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  messages       ChatMessage[]
  participants   ChatParticipant[]
  matchRequest   MatchRequest?     @relation(fields: [matchRequestId], references: [id])

  @@map("chat_rooms")
}

model ChatParticipant {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id        String    @id @default(cuid())
  roomId    String
  senderId  String
  content   String    @db.VarChar(2000)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  room      ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id])

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model UserRating {
  id             String       @id @default(cuid())
  matchRequestId String
  fromUserId     String
  toUserId       String
  score          Int
  comment        String?      @db.VarChar(500)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  fromUser       User         @relation("RatingFrom", fields: [fromUserId], references: [id])
  matchRequest   MatchRequest @relation(fields: [matchRequestId], references: [id])
  toUser         User         @relation("RatingTo", fields: [toUserId], references: [id])

  @@unique([matchRequestId, fromUserId])
  @@index([toUserId])
  @@map("user_ratings")
}

enum MatchingType {
  ONE_TO_ONE
  GROUP
}

enum QuizProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}
